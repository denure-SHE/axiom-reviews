---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { title, description = 'A journal of AI governance, policy analysis, and management fiction.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/x-icon" href="/axiomsreview.ico">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content="/architecture-cover.png">
  <title>{title} · Axiom Review</title>
</head>
<body>
  <Header />
  <slot />
  <Footer />
</body>
</html>
