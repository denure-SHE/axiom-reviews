---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { title, description = 'A journal of AI governance, policy analysis, and management fiction.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/x-icon" href="/axiomsreview.ico">
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%23f5f2ee'/><circle cx='50' cy='50' r='28' fill='none' stroke='%239a6f2e' stroke-width='6'/><line x1='50' y1='20' x2='50' y2='80' stroke='%239a6f2e' stroke-width='6'/><line x1='30' y1='38' x2='70' y2='38' stroke='%239a6f2e' stroke-width='5'/><line x1='25' y1='55' x2='75' y2='55' stroke='%239a6f2e' stroke-width='4'/></svg>">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content="/architecture-cover.png">
  <title>{title} · Axiom Review</title>
</head>
<body>
  <Header />
  <slot />
  <Footer />
</body>
</html>
