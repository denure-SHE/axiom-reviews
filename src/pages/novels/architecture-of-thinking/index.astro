---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const chapters = [
  { num: "—",  label: "Introduction",      title: "Introduction",                              slug: "introduction",  desc: "Who governs the reasoning of the systems we build? The questions Ananya faces at work echo in the most ordinary moments at home.", time: "8" },
  { num: "01", label: "Chapter One",       title: "The Pattern Beneath the Noise",             slug: "chapter-01",    desc: "Mira's first day of school and a financial risk engine both reveal the same truth — systems don't break all at once. They drift.", time: "10" },
  { num: "02", label: "Chapter Two",       title: "Signals",                                   slug: "chapter-02",    desc: "A shadow model begins running quietly behind the primary system, watching trajectories instead of events.", time: "10" },
  { num: "03", label: "Chapter Three",     title: "The Cost of Seeing Earlier",                slug: "chapter-03",    desc: "Four months of running ASD alongside the legacy engine — noise, resistance, exhaustion, and one validation that changes everything.", time: "15" },
  { num: "04", label: "Chapter Four",      title: "When Recognition Invites Resistance",       slug: "chapter-04",    desc: "ASD appears in the quarterly deck without her name. The question shifts from whether the architecture works, to whether the organization will invest.", time: "10" },
  { num: "05", label: "Chapter Five",      title: "Quiet Coalitions",                          slug: "chapter-05",    desc: "Building alliances one department at a time. Shared ownership is the key to reducing resistance.", time: "10" },
  { num: "06", label: "Chapter Six",       title: "When the Future Is Seen Before It Happens", slug: "chapter-06",    desc: "The high-stakes client presentation. ASD steps into the market. Three words shift the room: 'We absorb the cost.'", time: "10" },
  { num: "07", label: "Chapter Seven",     title: "The Work After the Win",                    slug: "chapter-07",    desc: "Recognition changes posture, not workload. The real credibility is built not in the moment of the win, but in the work that follows.", time: "10" },
  { num: "08", label: "Chapter Eight",     title: "The Space Between Yes and No",              slug: "chapter-08",    desc: "Calibration drift, a team running on fumes, and Mira navigating a new school group. Every negotiation asks for the same thing: stability.", time: "10" },
  { num: "09", label: "Chapter Nine",      title: "What Gets Handed Over",                     slug: "chapter-09",    desc: "A competitor enters the space. Delegation creates new vulnerabilities. Scale requires letting go — without losing direction.", time: "10" },
  { num: "10", label: "Chapter Ten",       title: "Lines That Cannot Blur",                    slug: "chapter-10",    desc: "An output mismatch surfaces. Promises were made without ownership. Clarity ends conflict faster than authority.", time: "10" },
  { num: "11", label: "Chapter Eleven",    title: "The Space Between Holding and Letting Go",  slug: "chapter-11",    desc: "A weekend without agenda. Ananya learns that presence does not diminish when shared — it expands.", time: "10" },
  { num: "12", label: "Chapter Twelve",    title: "What We Call Strength",                     slug: "chapter-12",    desc: "Over coffee with Neha, Ananya confronts the invisible architecture of how she holds things together — and what it costs.", time: "10" },
  { num: "13", label: "Chapter Thirteen",  title: "Where Power Sits",                          slug: "chapter-13",    desc: "ASD surfaces an early signal. Ananya's name disappears from the narrative. Strong leaders compete on outcomes, not influence.", time: "8" },
  { num: "14", label: "Chapter Fourteen",  title: "What Gets Named",                           slug: "chapter-14",    desc: "Her graphs appear on a slide without her name. At home, credit warms the room. At work, credit directs momentum.", time: "8" },
  { num: "15", label: "Chapter Fifteen",   title: "Who Gets to Decide",                        slug: "chapter-15",    desc: "A five-day offsite with no defined objectives. Ananya restructures the agenda. Clarity rarely needs attribution — only adoption.", time: "8" },
  { num: "16", label: "Chapter Sixteen",   title: "Order in the Middle of Noise",              slug: "chapter-16",    desc: "The client workshop fractures into parallel conversations. A chance meeting with an old friend. Confidence is not speed — it is predictability.", time: "8" },
  { num: "17", label: "Chapter Seventeen", title: "What Moves Without Authority",              slug: "chapter-17",    desc: "Decisions follow clarity, not hierarchy. A governance map replaces slides. Authority announces itself; influence circulates.", time: "8" },
  { num: "18", label: "Chapter Eighteen",  title: "When Clarity Threatens Someone",            slug: "chapter-18",    desc: "The system holds without her voice. Expertise builds systems; visibility builds narratives. Designing clarity is technical. Protecting it is human.", time: "8" },
];
---

<BaseLayout title="The Architecture of Thinking" description="On Judgment, Machines, and Reasoning. A management fiction by Daina Emmanuel.">
  <style>
    .novel-hero { display: grid; grid-template-columns: 320px 1fr; border-bottom: 1px solid var(--border); min-height: 480px; }
    .cover-col { background: #ffffff; border-right: 1px solid var(--border); display: flex; align-items: center; justify-content: center; padding: 3rem; }
    .cover-col img { width: 200px; box-shadow: 16px 16px 0 rgba(0,0,0,0.5); transition: transform 0.3s; }
    .cover-col img:hover { transform: translateY(-4px); }
    .detail-col { padding: clamp(3rem,6vw,5rem) clamp(2rem,5vw,4rem); display: flex; flex-direction: column; justify-content: center; }
    .novel-kicker { font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.25rem; display: flex; align-items: center; gap: 10px; }
    .novel-kicker::before { content: ''; width: 20px; height: 1px; background: var(--gold-dim); display: block; }
    .novel-title { font-family: var(--serif); font-size: clamp(2.4rem,4.5vw,4rem); font-weight: 300; line-height: 1.05; color: var(--text-primary); letter-spacing: -0.02em; margin-bottom: 0.5rem; }
    .novel-subtitle { font-family: var(--serif); font-style: italic; font-size: clamp(1rem,2vw,1.4rem); color: var(--gold); margin-bottom: 1.75rem; }
    .novel-byline { font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 2rem; }
    .novel-byline span { color: var(--text-secondary); }
    .novel-desc { font-size: 0.95rem; color: var(--text-secondary); line-height: 1.85; max-width: 540px; margin-bottom: 2.5rem; }
    .hero-stats { display: flex; gap: 2.5rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); margin-bottom: 1.5rem; }
    .h-stat .num { font-family: var(--serif); font-size: 2rem; font-weight: 300; color: var(--text-primary); line-height: 1; display: block; margin-bottom: 2px; }
    .h-stat .lbl { font-size: 0.6rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--text-muted); }
    .tags { display: flex; gap: 0.6rem; flex-wrap: wrap; }
    .tag { font-size: 0.6rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--text-secondary); border: 1px solid var(--border); padding: 4px 10px; border-radius: 1px; }
    .tag.gold { color: var(--gold); border-color: var(--gold-dim); }
    .chapters-section { padding: 4rem 0; }
    .ch-section-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border); }
    .ch-section-title { font-family: var(--serif); font-size: 1.4rem; font-weight: 400; color: var(--text-primary); display: flex; align-items: center; gap: 1rem; }
    .ch-section-title::after { content: ''; width: 30px; height: 1px; background: var(--gold-dim); }
    .chapters-list { display: flex; flex-direction: column; gap: 0; }
    .chapter-row { display: grid; position: relative; grid-template-columns: 72px 1fr auto; align-items: center; gap: 2rem; padding: 1.75rem 2rem; border: 1px solid var(--border); border-top: none; cursor: pointer; transition: background 0.2s; text-decoration: none; color: inherit; position: relative; }
    .chapter-row:first-child { border-top: 1px solid var(--border); }
    .chapter-row::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: transparent; transition: background 0.2s; pointer-events: none; }
    .chapter-row:hover { background: var(--bg-card); }
    .chapter-row:hover::before { background: var(--gold-dim); }
    .ch-num { font-family: var(--serif); font-size: 2.2rem; font-weight: 300; color: var(--text-muted); opacity: 0.3; line-height: 1; text-align: right; }
    .ch-label { font-size: 0.58rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 0.35rem; }
    .ch-title { font-family: var(--serif); font-size: 1.25rem; font-weight: 400; color: var(--text-primary); line-height: 1.25; margin-bottom: 0.4rem; }
    .ch-desc { font-size: 0.82rem; color: var(--text-secondary); line-height: 1.65; max-width: 560px; }
    .ch-meta { display: flex; gap: 1rem; margin-top: 0.6rem; font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); }
    .ch-right { display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; }
    .ch-read-btn { font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); border-bottom: 1px solid var(--gold-dim); padding-bottom: 2px; white-space: nowrap; }
    .author-section { background: var(--bg-card); border: 1px solid var(--border); padding: 2.5rem 3rem; margin-bottom: 4rem; display: flex; align-items: center; gap: 2rem; }
    .author-avatar { width: 64px; height: 64px; border-radius: 50%; background: #ffffff; border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-family: var(--serif); font-size: 1.4rem; color: var(--gold); flex-shrink: 0; }
    .author-info h4 { font-family: var(--serif); font-size: 1.2rem; font-weight: 400; color: var(--text-primary); margin-bottom: 0.25rem; }
    .author-info .role { font-size: 0.65rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold-dim); margin-bottom: 0.75rem; }
    .author-info p { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.75; max-width: 580px; }
    @media(max-width:860px){.novel-hero{grid-template-columns:1fr;}.cover-col{display:none;}.chapter-row{grid-template-columns:48px 1fr;}.ch-right{display:none;}}
  </style>

  <!-- HERO -->
  <div class="novel-hero">
    <div class="cover-col">
      <img src="/architecture-cover.png" alt="The Architecture of Thinking — Daina Emmanuel">
    </div>
    <div class="detail-col">
      <div class="novel-kicker">Management Fiction · Now Publishing</div>
      <h1 class="novel-title">The Architecture<br>of Thinking</h1>
      <div class="novel-subtitle">On Judgment, Machines, and Reasoning</div>
      <div class="novel-byline">By <span>Daina Emmanuel</span> &nbsp;·&nbsp; Begun 2025</div>
      <p class="novel-desc">A leader navigating the intersection of technology, risk, and organizational decision-making discovers that the hardest questions about intelligent systems are not technical — they are institutional, ethical, and deeply human. Told in parallel across the boardroom and the kitchen table.</p>
      <div class="hero-stats">
        <div class="h-stat"><span class="num">18</span><span class="lbl">Chapters published</span></div>
        <div class="h-stat"><span class="num">~175</span><span class="lbl">Min reading</span></div>
        <div class="h-stat"><span class="num">2025</span><span class="lbl">Series begun</span></div>
      </div>
      <div class="tags">
        <span class="tag gold">AI Governance</span>
        <span class="tag">Risk Management</span>
        <span class="tag">Organizational Systems</span>
        <span class="tag">Leadership</span>
      </div>
    </div>
  </div>

  <!-- CHAPTERS -->
  <div class="container">
    <div class="chapters-section">
      <div class="ch-section-header">
        <h2 class="ch-section-title">Chapters</h2>
      </div>
      <div class="chapters-list">
        {chapters.map((ch) => (
          <a href={`/novels/architecture-of-thinking/${ch.slug}`} class="chapter-row">
            <div class="ch-num">{ch.num}</div>
            <div>
              <div class="ch-label">{ch.label}</div>
              <div class="ch-title">{ch.title}</div>
              <div class="ch-desc">{ch.desc}</div>
              <div class="ch-meta"><span>2025</span><span>·</span><span>{ch.time} min read</span></div>
            </div>
            <div class="ch-right">
              <span class="ch-read-btn">Read →</span>
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="author-section">
      <div class="author-avatar">DE</div>
      <div class="author-info">
        <h4>Daina Emmanuel</h4>
        <div class="role">Author · Axiom Review</div>
        <p>Daina Emmanuel writes on AI governance, organizational judgment, and the human dimensions of intelligent systems. The Architecture of Thinking is her debut management fiction, published exclusively on Axiom Review.</p>
      </div>
    </div>
  </div>
</BaseLayout>
